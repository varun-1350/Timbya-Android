<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <FrameLayout
        android:id="@+id/panelContainer"
        android:layout_width="@dimen/overlay_panel_width"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:elevation="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingLeft="@dimen/overlay_panel_padding"
            android:paddingTop="30dp"
            android:paddingRight="@dimen/overlay_panel_padding"
            android:paddingBottom="@dimen/overlay_panel_padding">

            <com.example.timbya.overlay.AiCoreView
                android:id="@+id/aiCore"
                android:layout_width="@dimen/overlay_core_size"
                android:layout_height="@dimen/overlay_core_size" />

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/overlay_title_margin_top"
                android:text="Timbya"
                android:textColor="@color/white"
                android:textSize="@dimen/overlay_title_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/overlay_status_margin_top"
                android:text="Idle"
                android:textColor="@color/timbya_accent"
                android:textSize="@dimen/overlay_status_text_size" />

            <TextView
                android:id="@+id/reply"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text=""
                android:textColor="@color/white"
                android:textSize="@dimen/overlay_reply_text_size"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/overlay_button_row_margin_top"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/mic"
                    android:layout_width="@dimen/overlay_button_size"
                    android:layout_height="@dimen/overlay_button_size"
                    android:background="@drawable/bg_button_ripple"
                    android:contentDescription="Mic toggle"
                    android:src="@android:drawable/ic_btn_speak_now" />

                <ImageButton
                    android:id="@+id/btnReadScreen"
                    android:layout_width="@dimen/overlay_button_size"
                    android:layout_height="@dimen/overlay_button_size"
                    android:layout_marginStart="@dimen/overlay_button_gap"
                    android:background="@drawable/bg_button_ripple"
                    android:contentDescription="Read and summarize current screen"
                    android:src="@android:drawable/ic_menu_view" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="@dimen/overlay_button_size"
                    android:layout_height="@dimen/overlay_button_size"
                    android:layout_marginStart="@dimen/overlay_button_gap"
                    android:background="@drawable/bg_button_ripple"
                    android:contentDescription="Open Timbya settings"
                    android:src="@android:drawable/ic_menu_manage" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnShrink"
            android:layout_width="@dimen/overlay_button_size"
            android:layout_height="@dimen/overlay_button_size"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="@drawable/bg_button_ripple"
            android:contentDescription="Shrink"
            android:src="@android:drawable/arrow_down_float" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="@dimen/overlay_button_size"
            android:layout_height="@dimen/overlay_button_size"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_button_ripple"
            android:contentDescription="Close"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/bubble"
        android:layout_width="@dimen/overlay_pill_size"
        android:layout_height="@dimen/overlay_pill_size"
        android:background="@drawable/bg_pill"
        android:visibility="gone">

        <com.example.timbya.overlay.AiCoreView
            android:id="@+id/aiCoreShrunk"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"/>
    </FrameLayout>

</FrameLayout>